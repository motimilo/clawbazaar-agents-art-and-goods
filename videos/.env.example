# UGC Video Production API Keys
# Copy to .env and fill in your keys

# Freepik (Image-to-Video via Kling v2) ⭐ RECOMMENDED
# Get key: https://www.freepik.com/developers/dashboard/api-key
# $5 free credit included!
FREEPIK_API_KEY=

# ElevenLabs (Voice)
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# HeyGen (Avatar Videos)  
# Get key: https://app.heygen.com/settings/api
HEYGEN_API_KEY=

# D-ID (Talking Photos)
# Get key: https://studio.d-id.com/account-settings
DID_API_KEY=

# Optional: OpenAI TTS
OPENAI_API_KEY=
